rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the request is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get the requesting user's role from their user doc
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: check if the user has one of the allowed roles
    function hasRole(roles) {
      return isAuth() && getUserRole() in roles;
    }

    // Users collection — self-managed, admins manage all
    match /users/{uid} {
      allow create: if isAuth() && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['name', 'email', 'role', 'phone', 'region', 'profilePic', 'createdAt'])
        && !request.resource.data.keys().hasAny(['password']);
      allow read: if isAuth() && (request.auth.uid == uid || hasRole(['Taj Operations Lead', 'Regional Director']));
      allow update: if isAuth() && (request.auth.uid == uid || hasRole(['Taj Operations Lead', 'Regional Director']))
        && !request.resource.data.keys().hasAny(['password']);
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Projects — ops lead and director manage, all authenticated read
    match /projects/{projectId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
      allow update: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director', 'Maintenance Supervisor']);
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Leads — sales/ops manage, all authenticated read
    match /leads/{leadId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Breakdowns — all authenticated can read and create, dispatch restricted
    match /breakdowns/{breakdownId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // PM Slots — all authenticated read, ops create/update, tech can update assigned
    match /pm_slots/{slotId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director', 'Maintenance Supervisor']);
      allow update: if isAuth()
        && (hasRole(['Taj Operations Lead', 'Regional Director', 'Maintenance Supervisor'])
          || (hasRole(['Field Technician']) && resource.data.assignedTo == request.auth.uid));
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Inspections — tech creates and reads own, ops/director read all
    match /inspections/{inspectionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth()
        && (request.auth.uid == resource.data.createdBy || hasRole(['Taj Operations Lead', 'Regional Director']));
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Payments — finance/ops manage, all authenticated read
    match /payments/{paymentId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
      allow update: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Proposals — all authenticated read, ops create/update
    match /proposals/{proposalId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
      allow update: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
      allow delete: if isAuth() && hasRole(['Taj Operations Lead', 'Regional Director']);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
